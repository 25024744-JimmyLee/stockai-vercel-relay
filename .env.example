# Server-only values. Never expose these through NEXT_PUBLIC_* or commit real secrets.
STOCKAI_RELAY_TOKEN=replace-with-a-long-random-token
# Optional second shared token for the server-side Web BFF. This keeps the
# existing Flutter/Remote Config credential valid when the web app is deployed.
STOCKAI_WEB_BFF_TOKEN=
# Optional per-endpoint overrides; omitted values fall back to STOCKAI_RELAY_TOKEN.
STOCKAI_QUERY_TOKEN=
STOCKAI_INSIGHT_TOKEN=
STOCKAI_SYNC_TOKEN=
STOCKAI_MARKET_TOKEN=

# Vercel Cron sends this value as Authorization: Bearer <CRON_SECRET>.
# Keep it server-only and use a long random value.
CRON_SECRET=replace-with-a-long-random-secret

# Cross-origin browser callers must be listed. Same-origin requests and native/server
# callers without an Origin header remain valid. Use * only for an intentional demo.
STOCKAI_ALLOWED_ORIGINS=https://stockai.example

GEMINI_API_KEY=replace-with-server-api-key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_QUERY_MODEL=gemini-3.5-flash
GEMINI_INSIGHT_MODEL=gemini-3.5-flash
# Client-requested models are rejected unless present here. The configured model is
# always allowed even when these lists are empty.
GEMINI_ALLOWED_MODELS=gemini-3.5-flash
GEMINI_QUERY_ALLOWED_MODELS=
GEMINI_INSIGHT_ALLOWED_MODELS=

FIREBASE_PROJECT_ID=replace-with-project-id
FIREBASE_CLIENT_EMAIL=replace-with-service-account-email
FIREBASE_PRIVATE_KEY=replace-with-private-key-and-preserve-escaped-newlines
FIREBASE_ACCOUNT_SYNC_COLLECTION=mobile_account_sync
FIREBASE_MARKET_DATA_COLLECTION=market_data

# Optional public GitHub snapshot storage. Set this to github to stop market
# refreshes from reading/writing Firestore. The token must have Contents: Read
# and write access to the snapshot repository only.
STOCKAI_MARKET_DATA_STORAGE=firestore
STOCKAI_GITHUB_TOKEN=replace-with-fine-grained-github-token
STOCKAI_GITHUB_REPOSITORY=25024744-JimmyLee/stockai-market-snapshot
STOCKAI_GITHUB_BRANCH=main
STOCKAI_GITHUB_PATH=market-data.json
# Comma-separated universe used for the first GitHub refresh. After the first
# commit, the existing snapshot can supply the universe when this is omitted.
STOCKAI_MARKET_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,TSLA,META,BRK-B,JPM,V,UNH,JNJ,XOM,CVX,PG,HD,KO,PEP,AVGO,LLY
